{
  "manifest_version": 3,
  "name": "Browser Monitor",
  "version": "1.0.0",
  "minimum_chrome_version": "120",
  "description": "Analyzes Chrome tabs and provides local ad, tracker, distraction, cookie-banner, and custom element controls.",
  "icons": {
    "16": "icons/browser-monitor-16.png",
    "32": "icons/browser-monitor-32.png",
    "48": "icons/browser-monitor-48.png",
    "128": "icons/browser-monitor-128.png"
  },
  "permissions": [
    "alarms",
    "contextMenus",
    "declarativeNetRequest",
    "scripting",
    "storage",
    "tabs"
  ],
  "optional_permissions": [
    "clipboardWrite",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "easylist",
        "enabled": true,
        "path": "rules/easylist-network.json"
      },
      {
        "id": "easyprivacy",
        "enabled": true,
        "path": "rules/easyprivacy-network.json"
      }
    ]
  },
  "action": {
    "default_title": "Browser Monitor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/browser-monitor-16.png",
      "32": "icons/browser-monitor-32.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/image-swap-*.svg",
        "icons/browser-monitor-core.svg"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}
